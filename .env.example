# ─────────────────────────────────────────────────────────────────
# Agitator Rye — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# Sarvam AI (LLM Provider)
SARVAM_API_KEY=sk_your_sarvam_api_key_here
SARVAM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_MODEL=sarvam-m

# LangSmith (Tracing & Observability)
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agitator-rye

# Database
DATABASE_URL=sqlite:///./agitator_rye.db

# API Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security (set a strong secret in production)
SECRET_KEY=agitator-rye-dev-secret-change-in-production
